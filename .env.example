# Banco de dados
POSTGRES_DB=netmonitor
POSTGRES_USER=netmonitor
POSTGRES_PASSWORD=troque-esta-senha

# Segurança da aplicação (JWT) - gere uma string aleatória longa
SECRET_KEY=troque-por-uma-string-aleatoria-bem-grande

# Usuário admin criado automaticamente no primeiro start
ADMIN_USER=admin
ADMIN_PASSWORD=troque-esta-senha-tambem

# Alertas via Discord (webhook do canal). Deixe vazio para desativar.
DISCORD_WEBHOOK_URL=

# Parâmetros de monitoramento
PING_INTERVAL_SECONDS=60
PING_COUNT=4
PING_CONCURRENCY=20
LATENCY_WARN_MS=100
LOSS_WARN_PCT=20
OFFLINE_CONFIRM_CYCLES=2

# Retenção: dias de histórico detalhado; mais antigo vira agregado por hora
RETENTION_DETAIL_DAYS=30

# Monitor de qualidade da internet (speedtest)
# Atenção: cada teste consome banda real e satura o link por ~30s.
# 10 min é agressivo; em produção considere 30 ou 60.
SPEEDTEST_ENABLED=true
SPEEDTEST_INTERVAL_MINUTES=10
SPEEDTEST_MIN_DOWNLOAD_MBPS=100
SPEEDTEST_MIN_UPLOAD_MBPS=20
SPEEDTEST_MAX_PING_MS=60
